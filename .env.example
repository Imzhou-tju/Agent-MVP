# Clawgent 环境配置示例文件
# 复制此文件为 .env 并根据实际情况修改
# cp .env.example .env

# ==================== 模型配置 ====================

# 默认模型提供商 (可选：openai, anthropic, aliyun, tencent, z.ai, ollama, other)
DEFAULT_PROVIDER=aliyun

# 默认模型名称
DEFAULT_MODEL=glm-5

# ==================== OpenAI 兼容配置 ====================
# 适用于：OpenAI、阿里云、腾讯云、Z.AI 等兼容接口

# API Key (必填，除非使用 Ollama)
OPENAI_API_KEY=sk-your-api-key-here

# Base URL (可选，使用官方接口可留空或注释)
# OpenAI 官方：https://api.openai.com/v1
# 阿里云：https://dashscope.aliyuncs.com/compatible-mode/v1
# 阿里云 coding: https://coding.dashscope.aliyuncs.com/v1
OPENAI_API_BASE=https://coding.dashscope.aliyuncs.com/v1

# ==================== Anthropic 配置 ====================
# 仅在 DEFAULT_PROVIDER=anthropic 时使用

# API Key
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Base URL (可选，使用代理时配置)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ==================== Ollama 配置 ====================
# 仅在 DEFAULT_PROVIDER=ollama 时使用

# Ollama 本地服务地址 (默认：http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ==================== RAG 知识库检索 ====================
# Embedding + Rerank（默认 SiliconFlow）
RAG_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANKER_API_KEY=
RAG_RERANKER_BASE_URL=https://api.siliconflow.cn/v1/rerank

# 多查询扩写用的 chat 模型（OpenAI 兼容）
RAG_LLM_MODEL=DeepSeek-V4-Flash
RAG_LLM_API_KEY=
RAG_LLM_BASE_URL=https://www.sophnet.com/api/open-apis/v1

RAG_CHUNK_SIZE=250
RAG_CHUNK_OVERLAP=50
RAG_INITIAL_TOP_K=15
RAG_TOP_K=4

# Research (Multi-Agent 调研系统)
TAVILY_API_KEY=
RESEARCH_MAX_CONCURRENT=5
